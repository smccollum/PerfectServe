    "body": {
      "contentType": "html",
      "content": "<html>\r\n<head>\r\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\">\r\n</head>\r\n<body>\r\n<br>\r\n<div class=\"me-email-text\" lang=\"en-US\" style=\"max-width:1024px; color:#242424; font-family:'Segoe UI','Helvetica Neue',Helvetica,Arial,sans-serif\">\r\n<div aria-hidden=\"true\" style=\"margin-bottom:24px; overflow:hidden; white-space:nowrap\">\r\n________________________________________________________________________________</div>\r\n<div style=\"margin-bottom:12px\"><span class=\"me-email-text\" style=\"font-size:20px; color:#242424; font-weight:600\">Microsoft Teams meeting</span>\r\n</div>\r\n<div style=\"margin-bottom:6px\"><span class=\"me-email-text\" style=\"font-size:20px; color:#242424; font-weight:600\">Join:\r\n</span><a href=\"https://teams.microsoft.com/meet/23177627437876?p=ywClqSIbBhQNsDZ56i\" id=\"meet_invite_block.action.join_link\" title=\"Meeting join\" aria-label=\"Meeting join\" class=\"me-email-link\" style=\"font-size:20px; text-decoration:underline; color:#5B5FC7\">https://teams.microsoft.com/meet/23177627437876?p=ywClqSIbBhQNsDZ56i</a>\r\n</div>\r\n<div style=\"margin-bottom:6px\"><span class=\"me-email-text-secondary\" style=\"font-size:14px; color:#616161\">Meeting ID:\r\n</span><span class=\"me-email-text\" style=\"font-size:14px; color:#242424\">231 776 274 378 76</span>\r\n</div>\r\n<div style=\"margin-bottom:32px\"><span class=\"me-email-text-secondary\" style=\"font-size:14px; color:#616161\">Passcode:\r\n</span><span class=\"me-email-text\" style=\"font-size:14px; color:#242424\">wc7no6Zt</span>\r\n</div>\r\n<div style=\"margin-bottom:12px; max-width:1024px\">\r\n<hr style=\"border:0; background:#616161; height:1px\">\r\n</div>\r\n<div style=\"margin-bottom:24px\"><a href=\"https://aka.ms/JoinTeamsMeeting?omkt=en-US\" id=\"meet_invite_block.action.help\" class=\"me-email-link\" style=\"font-size:14px; text-decoration:underline; color:#5B5FC7\">Need help?</a>\r\n<span style=\"color:#616161\">|</span> <a href=\"https://teams.microsoft.com/l/meetup-join/19%3ameeting_NTdmYTlhYzUtOTc2OS00YjY1LWE4YzEtMmU1MzkyY2E5OTBi%40thread.v2/0?context=%7b%22Tid%22%3a%22044552bb-445f-4032-a0c6-e3dc3e354698%22%2c%22Oid%22%3a%22003e4cc5-b0ef-4f10-9a91-d1c85bc54fca%22%7d\" id=\"meet_invite_block.action.join_link_compatibility\" class=\"me-email-link\" style=\"font-size:14px; text-decoration:underline; color:#5B5FC7\">\r\nSystem reference</a> </div>\r\n<div>\r\n<div style=\"margin-bottom:6px\"><span class=\"me-email-text\" style=\"font-size:16px; color:#242424; font-weight:600; margin-right:4px\">Dial in by phone</span>\r\n</div>\r\n<div style=\"margin-bottom:6px\"><a href=\"tel:+14694806297,,93216030#\" id=\"meet_invite_block.action.join_phone_number1\" class=\"me-email-link\" style=\"font-size:14px; text-decoration:underline; color:#5B5FC7; margin-right:6px\">+1 469-480-6297,,93216030#</a>\r\n<span class=\"me-email-text\" style=\"font-size:14px; color:#616161\">United States, Dallas</span>\r\n</div>\r\n<div style=\"margin-bottom:6px\"><a href=\"https://dialin.teams.microsoft.com/5d722d2e-63ff-4202-ae07-afc97108b03c?id=93216030\" id=\"meet_invite_block.action.join_phone_find_local_number\" class=\"me-email-link\" style=\"font-size:14px; text-decoration:underline; color:#5B5FC7\">Find\r\n a local number</a> </div>\r\n</div>\r\n<div style=\"margin-bottom:24px\"><span class=\"me-email-text-secondary\" style=\"font-size:14px; color:#616161\">Phone conference ID:\r\n</span><span class=\"me-email-text\" style=\"font-size:14px; color:#242424\">932 160 30#</span>\r\n</div>\r\n<div><span class=\"me-email-text-secondary\" style=\"font-size:14px; color:#616161\">For organizers:\r\n</span><a href=\"https://teams.microsoft.com/meetingOptions/?organizerId=003e4cc5-b0ef-4f10-9a91-d1c85bc54fca&amp;tenantId=044552bb-445f-4032-a0c6-e3dc3e354698&amp;threadId=19_meeting_NTdmYTlhYzUtOTc2OS00YjY1LWE4YzEtMmU1MzkyY2E5OTBi@thread.v2&amp;messageId=0&amp;language=en-US\" id=\"meet_invite_block.ac